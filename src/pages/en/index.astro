---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Micky van Zadelhoff — AI, Business & Automation"
  description="Micky van Zadelhoff helps businesses with AI workshops, builds digital products, and shares his experience as a digital nomad and entrepreneur."
  lang="en"
  dark={true}
  hideFooter={true}
>
  <!-- Background gradient blobs -->
  <div class="fixed inset-0 overflow-hidden pointer-events-none z-0">
    <div class="absolute top-1/4 left-1/4 w-[600px] h-[600px] rounded-full bg-purple-900/30 blur-[120px] animate-blob"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] rounded-full bg-accent-pink/15 blur-[100px] animate-blob-reverse"></div>
  </div>

  <!-- Main content -->
  <div class="relative z-10 min-h-screen flex flex-col justify-between px-6 sm:px-10">

    <!-- Hero text area -->
    <div class="flex-1 flex items-center justify-center max-w-4xl mx-auto w-full">
      <div class="text-center py-24 sm:py-32">

        <div id="hero-text" class="transition-all duration-500 ease-out">
          <p id="hero-content" class="text-hero sm:text-hero-lg text-white leading-snug sm:leading-snug"></p>
        </div>

        <!-- Press mentions -->
        <div class="mt-16 flex items-center justify-center gap-6 sm:gap-10">
          <span class="text-[11px] sm:text-xs uppercase tracking-[0.2em] text-white/20 font-medium">NRC</span>
          <span class="text-white/10">|</span>
          <span class="text-[11px] sm:text-xs uppercase tracking-[0.2em] text-white/20 font-medium">Nu.nl</span>
          <span class="text-white/10">|</span>
          <span class="text-[11px] sm:text-xs uppercase tracking-[0.2em] text-white/20 font-medium">Vice</span>
        </div>
      </div>
    </div>

    <!-- Slider -->
    <div class="pb-8 sm:pb-12 max-w-3xl mx-auto w-full">
      <div class="flex items-center gap-4 sm:gap-6">
        <span class="text-[10px] sm:text-xs uppercase tracking-[0.15em] text-white/40 font-medium whitespace-nowrap select-none">
          Careful
        </span>
        <div class="flex-1 relative group">
          <div class="absolute inset-0 h-full flex items-center">
            <div class="w-full h-[2px] bg-white/10 rounded-full">
              <div id="slider-fill" class="h-full rounded-full transition-all duration-150" style="width: 0%; background: linear-gradient(90deg, #7c3aed, #ec4899, #f97316);"></div>
            </div>
          </div>
          <input
            id="hero-slider"
            type="range"
            min="0"
            max="9"
            value="0"
            step="1"
            class="relative w-full h-8 appearance-none bg-transparent cursor-pointer z-10 slider-input"
          />
        </div>
        <span class="text-[10px] sm:text-xs uppercase tracking-[0.15em] text-white/40 font-medium whitespace-nowrap select-none">
          I want it all
        </span>
      </div>

      <div class="flex justify-center gap-1.5 mt-4">
        {Array.from({ length: 10 }).map((_, i) => (
          <div
            class="w-1.5 h-1.5 rounded-full bg-white/10 transition-all duration-300 stage-dot"
            data-index={i}
          />
        ))}
      </div>
    </div>
  </div>
</Layout>

<style>
  .slider-input::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: white;
    cursor: pointer;
    box-shadow: 0 0 20px rgba(124, 58, 237, 0.5), 0 0 40px rgba(236, 72, 153, 0.2);
    transition: box-shadow 0.3s ease, transform 0.15s ease;
  }
  .slider-input::-webkit-slider-thumb:hover {
    transform: scale(1.15);
    box-shadow: 0 0 25px rgba(124, 58, 237, 0.7), 0 0 50px rgba(236, 72, 153, 0.3);
  }
  .slider-input::-moz-range-thumb {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: white;
    cursor: pointer;
    border: none;
    box-shadow: 0 0 20px rgba(124, 58, 237, 0.5), 0 0 40px rgba(236, 72, 153, 0.2);
  }
  .slider-input::-moz-range-track {
    background: transparent;
    border: none;
  }
  #hero-text.transitioning {
    opacity: 0;
    filter: blur(8px);
    transform: translateY(6px);
  }
  #hero-text {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0);
  }
  #hero-content :global(a) {
    text-decoration: underline;
    text-decoration-color: rgba(124, 58, 237, 0.6);
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
    transition: text-decoration-color 0.2s ease;
  }
  #hero-content :global(a:hover) {
    text-decoration-color: #ec4899;
  }
</style>

<script>
  const stages = [
    `Hi, I'm Micky. I help you hand off a few repetitive tasks to AI. Think sorting emails. Small things. Nobody has to know.`,

    `We automate your admin. Invoices, reports, the kind of work you've always dreaded. Your colleagues think you've just gotten faster.`,

    `Your entire marketing department now works in a quarter of the time. The other three quarters they spend in meetings about what to do with that time.`,

    `Your customer service runs entirely on AI. Available 24/7, never grumpy on Monday mornings, never asks for a raise.`,

    `We've now automated three job functions. HR hasn't noticed. I have.`,

    `Your management layer turns out to be largely replaceable. This surprises no one, but saying it out loud still feels strange.`,

    `You've deployed AI for strategy, creativity and decision-making. You still sign the contracts. For now.`,

    `Your calendar, your email, your LinkedIn, and your apologies to your partner are all written by AI. Nobody has noticed. Maybe it was always like this.`,

    `Your social life now runs through an AI that responds to messages on your behalf, remembers birthdays and resolves conflicts. Your friends actually think you've become more likeable.`,

    `Congratulations. You've automated everything. Your work, your communication, your friendships. You now have endless free time. For what? No idea. We probably should have discussed that earlier.`,
  ];

  function addLinks(text: string, stageIndex: number): string {
    if (stageIndex === 0) {
      return text.replace(
        'hand off a few repetitive tasks to AI',
        '<a href="/en/ai-workshop/">hand off a few repetitive tasks to AI</a>'
      );
    }
    if (stageIndex === 4) {
      return text.replace(
        'automated',
        '<a href="https://easyreimburse.ai">automated</a>'
      );
    }
    return text;
  }

  const slider = document.getElementById('hero-slider') as HTMLInputElement;
  const heroText = document.getElementById('hero-text')!;
  const heroContent = document.getElementById('hero-content')!;
  const sliderFill = document.getElementById('slider-fill')!;
  const dots = document.querySelectorAll('.stage-dot');

  let currentStage = 0;

  function updateStage(newStage: number) {
    if (newStage === currentStage && heroContent.innerHTML !== '') return;

    heroText.classList.add('transitioning');

    setTimeout(() => {
      heroContent.innerHTML = addLinks(stages[newStage], newStage);
      currentStage = newStage;

      const pct = (newStage / 9) * 100;
      sliderFill.style.width = pct + '%';

      dots.forEach((dot, i) => {
        if (i === newStage) {
          (dot as HTMLElement).style.background = 'rgba(124, 58, 237, 0.8)';
          (dot as HTMLElement).style.transform = 'scale(1.4)';
        } else if (i < newStage) {
          (dot as HTMLElement).style.background = 'rgba(124, 58, 237, 0.3)';
          (dot as HTMLElement).style.transform = 'scale(1)';
        } else {
          (dot as HTMLElement).style.background = 'rgba(255, 255, 255, 0.1)';
          (dot as HTMLElement).style.transform = 'scale(1)';
        }
      });

      heroText.classList.remove('transitioning');
    }, 250);
  }

  slider?.addEventListener('input', () => {
    updateStage(parseInt(slider.value, 10));
  });

  updateStage(0);
</script>
