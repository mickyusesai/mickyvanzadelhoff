---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
---

<Layout
  title="Over Micky van Zadelhoff — Digital Nomad, Ondernemer & AI-trainer"
  description="Leer Micky van Zadelhoff kennen: digital nomad, ondernemer, auteur, AI-trainer en Erasmus+ coördinator. Bekend van NRC, Vice, Nu.nl en meer."
  lang="nl"
  ogImage="/images/migrated/mick-van-zadelhoff-de-moderne-nomaden.webp"
>
  <PageHero
    title="Over Micky"
    subtitle="Digital nomad, ondernemer, auteur & luchtkasteelarchitect"
    badge="Hallo!"
    gradient="warm"
  />

  <div class="px-5 sm:px-8">
    <div class="max-w-5xl mx-auto">

      <!-- Intro with photo -->
      <section class="mb-24">
        <div class="grid grid-cols-1 md:grid-cols-5 gap-10 md:gap-16 items-center">
          <div class="md:col-span-3">
            <p class="text-lg text-ink/70 leading-relaxed mb-6">
              Ik ben Micky, geboren als millennial en levende als digital nomad. Vanuit telkens
              een andere plek doe ik mijn werk als blogger, business bouwer, trainer en liefdespartner.
              Dat laatste is natuurlijk niet écht werk te noemen ;).
            </p>
            <p class="text-lg text-ink/70 leading-relaxed">
              Tegenwoordig houdt ik mij vooral bezig met het ondersteunen van online ondernemers,
              het geven van <a href="/nl/ai-workshop/" class="text-purple-600 underline underline-offset-4 decoration-purple-300 hover:decoration-purple-600 transition-colors">AI & ChatGPT workshops</a>
              voor bedrijven, en verdiep ik me in de tech space.
            </p>
          </div>
          <div class="md:col-span-2">
            <div class="relative">
              <div class="absolute -inset-3 bg-gradient-to-br from-purple-200/40 to-accent-pink/20 rounded-[2rem] blur-lg"></div>
              <img
                src="/images/migrated/mick-van-zadelhoff-de-moderne-nomaden.webp"
                alt="Micky van Zadelhoff"
                class="relative rounded-3xl w-full shadow-xl"
              />
            </div>
          </div>
        </div>
      </section>

      <!-- Stats bar -->
      <section class="mb-24">
        <div class="bg-white rounded-3xl shadow-sm border border-purple-100/60 p-8 sm:p-10">
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 text-center">
            <div>
              <p class="text-3xl sm:text-4xl font-bold bg-gradient-to-r from-purple-600 to-accent-pink bg-clip-text text-transparent">1000+</p>
              <p class="text-sm text-ink/40 mt-1">mensen geholpen</p>
            </div>
            <div>
              <p class="text-3xl sm:text-4xl font-bold bg-gradient-to-r from-purple-600 to-accent-pink bg-clip-text text-transparent">50K</p>
              <p class="text-sm text-ink/40 mt-1">maandelijkse lezers</p>
            </div>
            <div>
              <p class="text-3xl sm:text-4xl font-bold bg-gradient-to-r from-purple-600 to-accent-pink bg-clip-text text-transparent">10K</p>
              <p class="text-sm text-ink/40 mt-1">nieuwsbrief abonnees</p>
            </div>
            <div>
              <p class="text-3xl sm:text-4xl font-bold bg-gradient-to-r from-purple-600 to-accent-pink bg-clip-text text-transparent">120+</p>
              <p class="text-sm text-ink/40 mt-1">artikelen</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Press logos -->
      <section class="mb-24">
        <p class="text-xs uppercase tracking-[0.2em] text-ink/30 font-medium mb-8">Bekend van</p>
        <div class="grid grid-cols-3 sm:grid-cols-6 gap-8 items-center">
          <div class="flex items-center justify-center h-16 bg-white rounded-2xl border border-purple-100/40 p-3 hover:shadow-md hover:border-purple-200/60 transition-all">
            <img src="/images/migrated/nrc-handelsblad.webp" alt="NRC" class="h-7 w-auto object-contain opacity-40 hover:opacity-80 transition-opacity" />
          </div>
          <div class="flex items-center justify-center h-16 bg-white rounded-2xl border border-purple-100/40 p-3 hover:shadow-md hover:border-purple-200/60 transition-all">
            <img src="/images/migrated/Nu-nl-logo-1.webp" alt="Nu.nl" class="h-7 w-auto object-contain opacity-40 hover:opacity-80 transition-opacity" />
          </div>
          <div class="flex items-center justify-center h-16 bg-white rounded-2xl border border-purple-100/40 p-3 hover:shadow-md hover:border-purple-200/60 transition-all">
            <img src="/images/migrated/Vice_Logo.webp" alt="Vice" class="h-7 w-auto object-contain opacity-40 hover:opacity-80 transition-opacity" />
          </div>
          <div class="flex items-center justify-center h-16 bg-white rounded-2xl border border-purple-100/40 p-3 hover:shadow-md hover:border-purple-200/60 transition-all">
            <img src="/images/migrated/algemeen-dagblad.webp" alt="AD" class="h-7 w-auto object-contain opacity-40 hover:opacity-80 transition-opacity" />
          </div>
          <div class="flex items-center justify-center h-16 bg-white rounded-2xl border border-purple-100/40 p-3 hover:shadow-md hover:border-purple-200/60 transition-all">
            <img src="/images/migrated/funx-logo.webp" alt="FunX" class="h-7 w-auto object-contain opacity-40 hover:opacity-80 transition-opacity" />
          </div>
          <div class="flex items-center justify-center h-16 bg-white rounded-2xl border border-purple-100/40 p-3 hover:shadow-md hover:border-purple-200/60 transition-all">
            <img src="/images/migrated/flow-logo.webp" alt="Flow" class="h-7 w-auto object-contain opacity-40 hover:opacity-80 transition-opacity" />
          </div>
        </div>
      </section>

      <!-- Three stories -->
      <section class="mb-24">
        <h2 class="text-2xl sm:text-3xl font-bold text-ink mb-12">Even voorstellen…</h2>
        <div class="space-y-8">
          <div class="group relative bg-white rounded-3xl p-8 sm:p-10 shadow-sm border border-purple-100/60 hover:shadow-md transition-all overflow-hidden">
            <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-purple-500 to-purple-300 rounded-l-3xl"></div>
            <div class="pl-4">
              <span class="inline-block text-xs font-bold text-purple-400 uppercase tracking-widest mb-3">01</span>
              <h3 class="text-xl font-semibold text-ink mb-4">Het gekste wat ik heb gedaan</h3>
              <p class="text-ink/60 leading-relaxed">
                Ik ben van Nederland naar Turkije gefietst terwijl ik wild kampeerde in een tent.
                Belangrijke details: ik had vooraf geen fietservaring en we vertrokken in het midden
                van de Europese winter. Als er iets is wat ik die reis heb geleerd dan is het wat de
                <strong class="text-ink/80">roes van een overlevingsinstinct</strong> is en hoe behulpzaam
                mensen wel niet zijn.
              </p>
            </div>
          </div>
          <div class="group relative bg-white rounded-3xl p-8 sm:p-10 shadow-sm border border-purple-100/60 hover:shadow-md transition-all overflow-hidden">
            <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-accent-pink to-purple-300 rounded-l-3xl"></div>
            <div class="pl-4">
              <span class="inline-block text-xs font-bold text-accent-pink uppercase tracking-widest mb-3">02</span>
              <h3 class="text-xl font-semibold text-ink mb-4">Het tofste wat ik heb gedaan</h3>
              <p class="text-ink/60 leading-relaxed">
                Beginnen met De Moderne Nomaden is zonder twijfel het tofste. Persoonlijk heb ik al
                1000 mensen mogen helpen richting een leven als digital nomad. Via mijn mailinglijst
                mag ik daarbij wekelijks 10.000 mensen inspireren. En die 122 artikelen die je op mijn
                website vindt, worden maandelijks zo'n 50.000 keer gelezen.
              </p>
            </div>
          </div>
          <div class="group relative bg-white rounded-3xl p-8 sm:p-10 shadow-sm border border-purple-100/60 hover:shadow-md transition-all overflow-hidden">
            <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-accent-orange to-accent-pink rounded-l-3xl"></div>
            <div class="pl-4">
              <span class="inline-block text-xs font-bold text-accent-orange uppercase tracking-widest mb-3">03</span>
              <h3 class="text-xl font-semibold text-ink mb-4">Het lompste wat ik heb gedaan</h3>
              <p class="text-ink/60 leading-relaxed mb-4">
                Ik dacht in een zomer dat het een goed idee zou zijn om 'air loungers' te verkopen op
                Ibiza. Dus ik importeerde er 200 vanuit China. In dat proces ging letterlijk alles mis.
                Het liep enorm in de kosten met als resultaat dat er nu nog altijd 165 'Ibiza Loungers'
                naar een goed doel zijn gegaan.
              </p>
              <blockquote class="pl-4 border-l-2 border-purple-300 text-ink/40 italic">
                "Geld is een bijkomstigheid van ondernemen, niet de drijfveer…"
              </blockquote>
            </div>
          </div>
        </div>
      </section>

      <!-- Press articles grid -->
      <section class="mb-24">
        <h2 class="text-2xl sm:text-3xl font-bold text-ink mb-12">In het nieuws</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <a href="https://www.nrc.nl/nieuws/2020/07/22/wat-doet-de-coronacrisis-met-de-digitale-nomade-a4006732" target="_blank" rel="noopener" class="group block rounded-2xl overflow-hidden bg-white border border-purple-100/60 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="overflow-hidden">
              <img src="/images/migrated/nrc-digitale-nomaden-corona.webp" alt="NRC artikel" class="w-full aspect-video object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <div class="p-5">
              <span class="inline-block px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider text-purple-600 bg-purple-50 rounded-full mb-2">NRC</span>
              <p class="text-sm font-semibold text-ink/70 group-hover:text-purple-600 transition-colors">Digitale nomaden en de coronacrisis</p>
            </div>
          </a>
          <a href="https://www.vice.com/nl/article/v7ekx8/stoppen-met-studie-slim" target="_blank" rel="noopener" class="group block rounded-2xl overflow-hidden bg-white border border-purple-100/60 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="overflow-hidden">
              <img src="/images/migrated/vice-interview-mick-van-zadelhoff.webp" alt="Vice interview" class="w-full aspect-video object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <div class="p-5">
              <span class="inline-block px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider text-purple-600 bg-purple-50 rounded-full mb-2">Vice</span>
              <p class="text-sm font-semibold text-ink/70 group-hover:text-purple-600 transition-colors">Stoppen met studie — slim of niet?</p>
            </div>
          </a>
          <a href="https://www.ad.nl/dordrecht/als-moderne-nomaden-naar-india-het-avontuur-begint-daar-waar-je-niet-weet-waar-het-eindigt~ab2e26bf/" target="_blank" rel="noopener" class="group block rounded-2xl overflow-hidden bg-white border border-purple-100/60 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="overflow-hidden">
              <img src="/images/migrated/ad-als-moderne-nomade-naar-india.webp" alt="AD artikel" class="w-full aspect-video object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <div class="p-5">
              <span class="inline-block px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider text-purple-600 bg-purple-50 rounded-full mb-2">AD</span>
              <p class="text-sm font-semibold text-ink/70 group-hover:text-purple-600 transition-colors">Als moderne nomaden naar India</p>
            </div>
          </a>
          <a href="https://www.flowmagazine.nl/doen/deze-nederlandse-jongens-fietsen-van-nederland-naar-india.html" target="_blank" rel="noopener" class="group block rounded-2xl overflow-hidden bg-white border border-purple-100/60 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="overflow-hidden">
              <img src="/images/migrated/flow-magazine-nederlandse-jongens-fietsen-van-nederland-naar-india.webp" alt="Flow Magazine" class="w-full aspect-video object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <div class="p-5">
              <span class="inline-block px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider text-purple-600 bg-purple-50 rounded-full mb-2">Flow</span>
              <p class="text-sm font-semibold text-ink/70 group-hover:text-purple-600 transition-colors">Van Nederland naar India op de fiets</p>
            </div>
          </a>
          <a href="https://www.funx.nl/fragmenten/tannaz/f9ea03c1-e754-46c7-bc5f-8040d939aa33/2021-09-14-stoppen-met-zijn-opleiding-is-de-beste-keuze-die-mick-ooit-heeft-gemaakt" target="_blank" rel="noopener" class="group block rounded-2xl overflow-hidden bg-white border border-purple-100/60 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="overflow-hidden">
              <img src="/images/migrated/mick-van-zadelhoff-funx.webp" alt="FunX interview" class="w-full aspect-video object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <div class="p-5">
              <span class="inline-block px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider text-purple-600 bg-purple-50 rounded-full mb-2">FunX</span>
              <p class="text-sm font-semibold text-ink/70 group-hover:text-purple-600 transition-colors">Stoppen met studie — de beste keuze</p>
            </div>
          </a>
          <a href="https://www.nu.nl/geldzaken/6148047/geld-verdienen-zonder-ervoor-te-werken-zo-doe-je-dat.html" target="_blank" rel="noopener" class="group block rounded-2xl overflow-hidden bg-white border border-purple-100/60 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="overflow-hidden">
              <img src="/images/migrated/passief.webp" alt="Nu.nl artikel" class="w-full aspect-video object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <div class="p-5">
              <span class="inline-block px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider text-purple-600 bg-purple-50 rounded-full mb-2">Nu.nl</span>
              <p class="text-sm font-semibold text-ink/70 group-hover:text-purple-600 transition-colors">Geld verdienen zonder ervoor te werken</p>
            </div>
          </a>
        </div>
      </section>

      <!-- CTA -->
      <section class="mb-24">
        <div class="relative bg-gradient-to-br from-purple-600 to-purple-800 rounded-3xl p-10 sm:p-14 text-center overflow-hidden">
          <div class="absolute top-0 right-0 w-48 h-48 rounded-full bg-white/5 blur-2xl"></div>
          <div class="absolute bottom-0 left-0 w-32 h-32 rounded-full bg-accent-pink/10 blur-2xl"></div>
          <div class="relative">
            <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">Wil je een bakje koffie doen?</h2>
            <p class="text-white/60 mb-8 max-w-lg mx-auto">Of gewoon even bellen. Ik hoor graag waar je mee bezig bent.</p>
            <a href="/nl/contact/" class="inline-flex items-center px-8 py-3 bg-white text-purple-700 font-semibold rounded-full hover:bg-purple-50 transition-colors shadow-lg">
              Neem contact op →
            </a>
          </div>
        </div>
      </section>
    </div>
  </div>
</Layout>
