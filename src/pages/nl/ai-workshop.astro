---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';

const programma = [
  { time: '10:00 – 10:30', title: 'Artifi... WAT?!', desc: 'Verken de wereld van kunstmatige intelligentie via een interactieve quiz. Direct duidelijkheid over machine learning, large language models en de laatste doorbraken.' },
  { time: '10:30 – 11:20', title: 'AI Use Cases', desc: 'Wat zijn de verschillende manieren om ChatGPT, Claude, Gemini en andere AI-tools in te zetten? We delen een zee aan voorbeelden en laten zien wat AI wél en (nog) niet kan.' },
  { time: '11:20 – 11:40', title: 'Koffie & Questions', desc: 'Kleine pauze om alle toekomstige ideeën te laten inzinken en vragen te beantwoorden.' },
  { time: '11:40 – 12:10', title: 'Aan de slag', desc: 'Medewerkers stellen een lijstje op met taken die AI voor hen uit kan voeren en beginnen met oefenen.' },
  { time: '12:10 – 12:40', title: 'Brede AI-toepassingen', desc: 'We duiken in de breedte van AI en bespreken interessante use cases voor marketing, klantenservice, administratie, communicatie, HR en sales.' },
  { time: '12:40 – 13:00', title: 'Bedrijf future proof', desc: 'Waar gaat het heen? Een kijkje in de toekomst van AI en de gevolgen voor werk en leven, gevolgd door een discussie onder de medewerkers.' },
];
---

<Layout
  title="AI & ChatGPT Workshop voor Bedrijven — Micky van Zadelhoff"
  description="In-company AI workshop van 3 uur. Praktisch, to-the-point en de investering binnen één week terugverdiend. €950 excl. btw."
  lang="nl"
  ogImage="/images/migrated/training-ai-kunstmatige-intelligentie-in-company-1.webp"
>
  <PageHero
    title="AI & ChatGPT Workshop"
    subtitle="In-company training van 3 uur. De investering die je bedrijf binnen één week terugverdient."
  />

  <div class="px-5 sm:px-8">
    <div class="max-w-5xl mx-auto">

      <!-- Intro -->
      <section class="mb-16">
        <p class="text-lg text-ink/70 leading-relaxed mb-6">
          De ontwikkelingen in AI gaan ontzettend snel. Van ChatGPT en Claude tot Gemini en
          duizenden gespecialiseerde AI-tools — het is duidelijk dat AI veel voor bedrijven
          kan betekenen. Maar door de bomen het bos zien? Dat is een ander verhaal.
        </p>
        <p class="text-lg text-ink/70 leading-relaxed">
          Laat AI de administratie doen, een campagne bedenken, een bedrijfsvideo maken,
          de contentstrategie uitvoeren, e-mails voor HR schrijven — de mogelijkheden zijn
          eindeloos. In deze 3-urige workshop ontdek je ze op een praktische, to-the-point
          manier.
        </p>
      </section>

      <!-- Training image -->
      <section class="mb-16">
        <img
          src="/images/migrated/training-ai-kunstmatige-intelligentie-in-company-1.webp"
          alt="AI Workshop in-company training"
          class="w-full rounded-2xl"
        />
      </section>

      <!-- Key stats -->
      <section class="mb-16">
        <div class="grid grid-cols-2 sm:grid-cols-5 gap-4">
          <div class="bg-white shadow-sm rounded-2xl p-5 text-center border border-purple-100/60">
            <p class="text-2xl font-bold text-ink">3</p>
            <p class="text-xs text-ink/40 mt-1">uur</p>
          </div>
          <div class="bg-white shadow-sm rounded-2xl p-5 text-center border border-purple-100/60">
            <p class="text-2xl font-bold text-ink">1</p>
            <p class="text-xs text-ink/40 mt-1">trainer</p>
          </div>
          <div class="bg-white shadow-sm rounded-2xl p-5 text-center border border-purple-100/60">
            <p class="text-2xl font-bold text-ink">25</p>
            <p class="text-xs text-ink/40 mt-1">max. deelnemers</p>
          </div>
          <div class="bg-white shadow-sm rounded-2xl p-5 text-center border border-purple-100/60">
            <p class="text-2xl font-bold text-ink">Op locatie</p>
            <p class="text-xs text-ink/40 mt-1">bij jou op kantoor</p>
          </div>
          <div class="bg-white shadow-sm rounded-2xl p-5 text-center border border-purple-100/60 col-span-2 sm:col-span-1">
            <p class="text-2xl font-bold text-purple-600">€950</p>
            <p class="text-xs text-ink/40 mt-1">excl. btw</p>
          </div>
        </div>
      </section>

      <!-- Programme -->
      <section class="mb-16">
        <h2 class="text-2xl sm:text-3xl font-bold text-ink mb-10">Programma</h2>
        <div class="space-y-6">
          {programma.map((item) => (
            <div class="flex gap-6 items-start">
              <div class="shrink-0 w-28 sm:w-32">
                <p class="text-sm font-medium text-purple-600">{item.time}</p>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-ink mb-1">{item.title}</h3>
                <p class="text-sm text-ink/50 leading-relaxed">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- FAQ -->
      <section class="mb-16">
        <h2 class="text-2xl sm:text-3xl font-bold text-ink mb-10">Veelgestelde vragen</h2>
        <div class="space-y-6">
          <div class="border-b border-purple-100/60 pb-6">
            <h3 class="text-ink font-medium mb-2">Waar is de training?</h3>
            <p class="text-sm text-ink/50 leading-relaxed">Bij jou op locatie. We hebben enkel een beamer of tv-scherm nodig voor de presentatie.</p>
          </div>
          <div class="border-b border-purple-100/60 pb-6">
            <h3 class="text-ink font-medium mb-2">Wat kost de training?</h3>
            <p class="text-sm text-ink/50 leading-relaxed">De investering is €950 excl. btw. Dit is inclusief reiskosten, trainer en voorbereiding.</p>
          </div>
          <div class="border-b border-purple-100/60 pb-6">
            <h3 class="text-ink font-medium mb-2">Wie geeft de training?</h3>
            <p class="text-sm text-ink/50 leading-relaxed">
              De training wordt gegeven door Micky van Zadelhoff. AI-expert en helemaal thuis in de tech wereld.
            </p>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section id="aanmelden" class="mb-20 bg-white shadow-sm rounded-3xl p-8 sm:p-12 border border-purple-100/60 text-center">
        <h2 class="text-2xl font-bold text-ink mb-4">Gesprek inplannen</h2>
        <p class="text-ink/50 leading-relaxed mb-8 max-w-lg mx-auto">
          We vinden het zelf het allerhandigst om gewoon even te mailen of appen. Dan maken we kennis!
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="mailto:mick@demodernenomaden.nl" class="inline-flex items-center justify-center px-8 py-3 bg-purple-600 text-white font-medium rounded-full hover:bg-purple-500 transition-colors">
            Mail ons
          </a>
          <a href="https://wa.me/31681081589" target="_blank" rel="noopener" class="inline-flex items-center justify-center px-8 py-3 border border-purple-100/60 text-ink font-medium rounded-full hover:bg-surface-200 transition-colors">
            WhatsApp
          </a>
        </div>
      </section>
    </div>
  </div>
</Layout>
