---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Micky van Zadelhoff — AI, Ondernemen & Automatisering"
  description="Micky van Zadelhoff helpt bedrijven met AI-workshops, bouwt digitale producten en deelt zijn ervaring als digital nomad en ondernemer."
  lang="nl"
  dark={true}
  hideFooter={true}
>
  <!-- Background gradient blobs -->
  <div class="fixed inset-0 overflow-hidden pointer-events-none z-0">
    <div class="absolute top-1/4 left-1/4 w-[600px] h-[600px] rounded-full bg-purple-900/30 blur-[120px] animate-blob"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] rounded-full bg-accent-pink/15 blur-[100px] animate-blob-reverse"></div>
  </div>

  <!-- Main content -->
  <div class="relative z-10 min-h-screen flex flex-col justify-between px-6 sm:px-10">

    <!-- Hero text area — vertically centered -->
    <div class="flex-1 flex items-center justify-center max-w-3xl mx-auto w-full">
      <div class="text-center py-24 sm:py-32">
        <div id="hero-text" class="transition-all duration-500 ease-out">
          <p id="hero-content" class="text-hero sm:text-hero-lg text-white/90 leading-relaxed sm:leading-relaxed"></p>
        </div>
      </div>
    </div>

    <!-- Bottom area: tagline + slider + press -->
    <div class="pb-6 sm:pb-10 max-w-3xl mx-auto w-full">

      <!-- AI Automation tagline above slider -->
      <p class="text-center text-[11px] sm:text-xs uppercase tracking-[0.25em] text-white/30 font-medium mb-6">
        Hoeveel van je bedrijf wil je automatiseren met AI?
      </p>

      <!-- Slider -->
      <div class="flex items-center gap-4 sm:gap-6">
        <span class="text-[10px] sm:text-xs uppercase tracking-[0.15em] text-white/40 font-medium whitespace-nowrap select-none">
          Voorzichtig
        </span>
        <div class="flex-1 relative group">
          <div class="absolute inset-0 h-full flex items-center">
            <div class="w-full h-[2px] bg-white/10 rounded-full">
              <div id="slider-fill" class="h-full rounded-full transition-all duration-150" style="width: 0%; background: linear-gradient(90deg, #7c3aed, #ec4899, #f97316);"></div>
            </div>
          </div>
          <input
            id="hero-slider"
            type="range"
            min="0"
            max="9"
            value="0"
            step="1"
            class="relative w-full h-8 appearance-none bg-transparent cursor-pointer z-10 slider-input"
          />
        </div>
        <span class="text-[10px] sm:text-xs uppercase tracking-[0.15em] text-white/40 font-medium whitespace-nowrap select-none">
          Ik wil alles
        </span>
      </div>

      <!-- Stage indicator dots -->
      <div class="flex justify-center gap-1.5 mt-4">
        {Array.from({ length: 10 }).map((_, i) => (
          <div
            class="w-1.5 h-1.5 rounded-full bg-white/10 transition-all duration-300 stage-dot"
            data-index={i}
          />
        ))}
      </div>

      <!-- Press mentions below slider -->
      <div class="mt-8 flex items-center justify-center gap-6 sm:gap-10">
        <span class="text-[10px] sm:text-[11px] uppercase tracking-[0.2em] text-white/15 font-medium">NRC</span>
        <span class="text-white/8">·</span>
        <span class="text-[10px] sm:text-[11px] uppercase tracking-[0.2em] text-white/15 font-medium">Nu.nl</span>
        <span class="text-white/8">·</span>
        <span class="text-[10px] sm:text-[11px] uppercase tracking-[0.2em] text-white/15 font-medium">Vice</span>
      </div>
    </div>
  </div>
</Layout>

<style>
  .slider-input::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: white;
    cursor: pointer;
    box-shadow: 0 0 20px rgba(124, 58, 237, 0.5), 0 0 40px rgba(236, 72, 153, 0.2);
    transition: box-shadow 0.3s ease, transform 0.15s ease;
  }
  .slider-input::-webkit-slider-thumb:hover {
    transform: scale(1.15);
    box-shadow: 0 0 25px rgba(124, 58, 237, 0.7), 0 0 50px rgba(236, 72, 153, 0.3);
  }
  .slider-input::-moz-range-thumb {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: white;
    cursor: pointer;
    border: none;
    box-shadow: 0 0 20px rgba(124, 58, 237, 0.5), 0 0 40px rgba(236, 72, 153, 0.2);
  }
  .slider-input::-moz-range-track {
    background: transparent;
    border: none;
  }
  #hero-text.transitioning {
    opacity: 0;
    filter: blur(8px);
    transform: translateY(6px);
  }
  #hero-text {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0);
  }
  #hero-content :global(a) {
    text-decoration: underline;
    text-decoration-color: rgba(124, 58, 237, 0.6);
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
    transition: text-decoration-color 0.2s ease;
  }
  #hero-content :global(a:hover) {
    text-decoration-color: #ec4899;
  }
</style>

<script>
  const stages = [
    `Hoi, ik ben Micky. Ik help je een paar repetitieve taakjes uit handen geven aan AI. Denk aan e-mails sorteren. Kleine dingen. Niemand hoeft het te weten.`,
    `We automatiseren je administratie. Facturen, rapportages, dat soort werk waar je altijd tegenop zag. Je collega's denken dat je gewoon sneller bent geworden.`,
    `Je hele marketingafdeling werkt nu op een kwart van de tijd. De andere driekwart besteden ze aan vergaderen over wat ze met die tijd moeten doen.`,
    `Je klantenservice draait volledig op AI. 24/7 beschikbaar, nooit chagrijnig op maandagochtend, vraagt nooit om loonsverhoging.`,
    `We hebben nu drie functies geautomatiseerd. HR heeft het nog niet opgemerkt. Ik wel.`,
    `Je managementlaag blijkt grotendeels vervangbaar. Dit verrast niemand, maar het hardop zeggen voelt nog steeds raar.`,
    `Je hebt AI ingezet voor strategie, creatie en besluitvorming. Jij tekent nog wel de contracten. Voorlopig.`,
    `Je agenda, je e-mail, je LinkedIn en je excuses aan je partner worden allemaal door AI geschreven. Niemand heeft iets gemerkt. Misschien was het altijd al zo.`,
    `Je sociale leven loopt nu via een AI die namens jou reageert op appjes, verjaardagen onthoudt en conflicten oplost. Je vrienden vinden je eigenlijk leuker geworden.`,
    `Gefeliciteerd. Je hebt alles geautomatiseerd. Je werk, je communicatie, je vriendschappen. Je hebt nu eindeloos veel vrije tijd. Waarvoor? Geen idee. Dat hadden we misschien eerder moeten bespreken.`,
  ];

  function addLinks(text: string, stageIndex: number): string {
    if (stageIndex === 0) {
      return text.replace(
        'uit handen geven aan AI',
        '<a href="/nl/ai-workshop/">uit handen geven aan AI</a>'
      );
    }
    if (stageIndex === 4) {
      return text.replace(
        'geautomatiseerd',
        '<a href="https://easyreimburse.ai">geautomatiseerd</a>'
      );
    }
    return text;
  }

  const slider = document.getElementById('hero-slider') as HTMLInputElement;
  const heroText = document.getElementById('hero-text')!;
  const heroContent = document.getElementById('hero-content')!;
  const sliderFill = document.getElementById('slider-fill')!;
  const dots = document.querySelectorAll('.stage-dot');
  let currentStage = 0;

  function updateStage(newStage: number) {
    if (newStage === currentStage && heroContent.innerHTML !== '') return;
    heroText.classList.add('transitioning');
    setTimeout(() => {
      heroContent.innerHTML = addLinks(stages[newStage], newStage);
      currentStage = newStage;
      const pct = (newStage / 9) * 100;
      sliderFill.style.width = pct + '%';
      dots.forEach((dot, i) => {
        if (i === newStage) {
          (dot as HTMLElement).style.background = 'rgba(124, 58, 237, 0.8)';
          (dot as HTMLElement).style.transform = 'scale(1.4)';
        } else if (i < newStage) {
          (dot as HTMLElement).style.background = 'rgba(124, 58, 237, 0.3)';
          (dot as HTMLElement).style.transform = 'scale(1)';
        } else {
          (dot as HTMLElement).style.background = 'rgba(255, 255, 255, 0.1)';
          (dot as HTMLElement).style.transform = 'scale(1)';
        }
      });
      heroText.classList.remove('transitioning');
    }, 250);
  }

  slider?.addEventListener('input', () => {
    updateStage(parseInt(slider.value, 10));
  });

  updateStage(0);
</script>
