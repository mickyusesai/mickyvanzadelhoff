---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
---

<Layout
  title="EasyReimburse — Declaraties makkelijk gemaakt"
  description="EasyReimburse is een SaaS-app gebouwd door Micky van Zadelhoff die declaraties eenvoudig en snel maakt voor teams en bedrijven."
  lang="nl"
>
  <PageHero
    title="EasyReimburse"
    subtitle="Declaraties makkelijk gemaakt. Gebouwd door Micky."
  />

  <div class="px-5 sm:px-8">
    <div class="max-w-5xl mx-auto">

      <!-- Intro -->
      <section class="mb-16">
        <p class="text-lg text-ink/70 leading-relaxed mb-6">
          EasyReimburse is een web-app die ik heb gebouwd om het declaratieproces voor teams
          en bedrijven drastisch te vereenvoudigen. Geen eindeloze Excel-bestanden meer,
          geen kwijtgeraakte bonnetjes — alles op één plek, helder en snel.
        </p>
        <p class="text-lg text-ink/70 leading-relaxed">
          Als ondernemer die zelf altijd bezig is met bouwen, weet ik hoe frustrerend
          administratieve rompslomp kan zijn. Dus bouwde ik de tool die ik zelf wilde hebben.
        </p>
      </section>

      <!-- Features -->
      <section class="mb-16">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div class="bg-white shadow-sm rounded-2xl p-6 border border-purple-100/60">
            <p class="text-3xl mb-3">📸</p>
            <h3 class="text-ink font-semibold mb-2">Bon uploaden</h3>
            <p class="text-sm text-ink/50">Foto maken, uploaden, klaar. De app leest de gegevens automatisch uit.</p>
          </div>
          <div class="bg-white shadow-sm rounded-2xl p-6 border border-purple-100/60">
            <p class="text-3xl mb-3">📊</p>
            <h3 class="text-ink font-semibold mb-2">Overzicht</h3>
            <p class="text-sm text-ink/50">Real-time inzicht in alle declaraties per medewerker, afdeling of project.</p>
          </div>
          <div class="bg-white shadow-sm rounded-2xl p-6 border border-purple-100/60">
            <p class="text-3xl mb-3">⚡</p>
            <h3 class="text-ink font-semibold mb-2">Snel afhandelen</h3>
            <p class="text-sm text-ink/50">Goedkeuren, afwijzen en exporteren in een paar klikken. Geen gedoe.</p>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="mb-20 text-center">
        <a
          href="https://easyreimburse.ai"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center px-8 py-4 bg-purple-600 text-white text-lg font-medium rounded-full hover:bg-purple-500 transition-colors"
        >
          Bekijk EasyReimburse →
        </a>
        <p class="text-ink/30 text-sm mt-4">easyreimburse.ai</p>
      </section>
    </div>
  </div>
</Layout>
