---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';

const features = [
  {
    icon: `<svg class="w-7 h-7 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0ZM18.75 10.5h.008v.008h-.008V10.5Z" /></svg>`,
    title: 'Bon uploaden',
    desc: 'Foto maken, uploaden, klaar. De app leest de gegevens automatisch uit met AI-powered OCR.',
    gradient: 'from-purple-500 to-purple-400',
  },
  {
    icon: `<svg class="w-7 h-7 text-accent-pink" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125Z" /></svg>`,
    title: 'Overzicht',
    desc: 'Real-time inzicht in alle declaraties per medewerker, afdeling of project. Alles op één dashboard.',
    gradient: 'from-accent-pink to-purple-400',
  },
  {
    icon: `<svg class="w-7 h-7 text-accent-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" /></svg>`,
    title: 'Snel afhandelen',
    desc: 'Goedkeuren, afwijzen en exporteren in een paar klikken. Geen gedoe, geen wachttijden.',
    gradient: 'from-accent-orange to-accent-pink',
  },
];

const steps = [
  { num: '01', title: 'Bon fotograferen', desc: 'Medewerker maakt een foto van de bon met de smartphone of upload een PDF.' },
  { num: '02', title: 'AI leest de bon', desc: 'Onze AI herkent automatisch het bedrag, de datum, het BTW-nummer en de categorie.' },
  { num: '03', title: 'Manager keurt goed', desc: 'De manager ontvangt een notificatie, bekijkt de declaratie en keurt goed met één klik.' },
];

const oudVsNieuw = {
  oud: [
    'Excel-bestanden heen en weer mailen',
    'Bonnetjes kwijtraken',
    'Handmatig bedragen overtypen',
    'Weken wachten op uitbetaling',
    'Geen overzicht per project',
  ],
  nieuw: [
    'Alles in één web-app',
    'Digitale bonnetjes, altijd bewaard',
    'AI leest bonnen automatisch uit',
    'Goedkeuring in real-time',
    'Dashboard per team, project of afdeling',
  ],
};
---

<Layout
  title="EasyReimburse — Declaraties makkelijk gemaakt"
  description="EasyReimburse is een SaaS-app gebouwd door Micky van Zadelhoff die declaraties eenvoudig en snel maakt voor teams en bedrijven."
  lang="nl"
>
  <PageHero
    title="EasyReimburse"
    subtitle="Declaraties makkelijk gemaakt. Gebouwd door Micky."
    badge="SaaS Product"
    gradient="pink"
  />

  <div class="px-5 sm:px-8">
    <div class="max-w-5xl mx-auto">

      <!-- Intro -->
      <section class="mb-20">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-14 items-center">
          <div>
            <p class="text-lg text-ink/70 leading-relaxed mb-6">
              EasyReimburse is een web-app die ik heb gebouwd om het declaratieproces voor teams
              en bedrijven drastisch te vereenvoudigen. Geen eindeloze Excel-bestanden meer,
              geen kwijtgeraakte bonnetjes — alles op één plek, helder en snel.
            </p>
            <p class="text-lg text-ink/70 leading-relaxed">
              Als ondernemer die zelf altijd bezig is met bouwen, weet ik hoe frustrerend
              administratieve rompslomp kan zijn. Dus bouwde ik de tool die ik zelf wilde hebben.
            </p>
          </div>
          <!-- App mockup -->
          <div class="relative">
            <div class="absolute -inset-4 bg-gradient-to-br from-accent-pink/20 via-purple-200/30 to-accent-blue/10 rounded-[2.5rem] blur-xl"></div>
            <div class="relative bg-gradient-to-br from-white to-purple-50 rounded-3xl border border-purple-100/60 shadow-xl p-6 sm:p-8">
              <!-- Fake app header -->
              <div class="flex items-center gap-3 mb-6">
                <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-accent-pink to-purple-500 flex items-center justify-center">
                  <span class="text-white text-xs font-bold">ER</span>
                </div>
                <span class="font-semibold text-ink text-sm">EasyReimburse</span>
                <div class="ml-auto flex gap-1.5">
                  <div class="w-2.5 h-2.5 rounded-full bg-green-400"></div>
                  <div class="w-2.5 h-2.5 rounded-full bg-purple-200"></div>
                </div>
              </div>
              <!-- Fake dashboard content -->
              <div class="space-y-3">
                <div class="h-3 w-3/4 bg-purple-100/60 rounded-full"></div>
                <div class="h-3 w-1/2 bg-purple-100/40 rounded-full"></div>
                <div class="mt-4 grid grid-cols-3 gap-3">
                  <div class="bg-purple-50 rounded-xl p-3 text-center">
                    <p class="text-lg font-bold bg-gradient-to-r from-purple-600 to-accent-pink bg-clip-text text-transparent">12</p>
                    <p class="text-[10px] text-ink/30 mt-0.5">In afwachting</p>
                  </div>
                  <div class="bg-green-50 rounded-xl p-3 text-center">
                    <p class="text-lg font-bold text-green-600">48</p>
                    <p class="text-[10px] text-ink/30 mt-0.5">Goedgekeurd</p>
                  </div>
                  <div class="bg-accent-pink/5 rounded-xl p-3 text-center">
                    <p class="text-lg font-bold text-accent-pink">€2.4k</p>
                    <p class="text-[10px] text-ink/30 mt-0.5">Deze maand</p>
                  </div>
                </div>
                <div class="mt-4 space-y-2">
                  {['Lunch klant — €34,50', 'Treinticket — €22,80', 'Software — €49,00'].map((item) => (
                    <div class="flex items-center justify-between bg-white rounded-lg p-2.5 border border-purple-50">
                      <span class="text-xs text-ink/60">{item}</span>
                      <span class="text-[10px] px-2 py-0.5 bg-green-50 text-green-600 rounded-full font-medium">OK</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Hoe het werkt -->
      <section class="mb-24">
        <h2 class="text-2xl sm:text-3xl font-bold text-ink mb-4">Hoe het werkt</h2>
        <p class="text-ink/50 mb-14 max-w-2xl">Drie stappen. Dat is alles.</p>

        <div class="relative">
          <!-- Dashed connector line (hidden on mobile) -->
          <div class="hidden sm:block absolute top-[52px] left-[calc(16.67%+24px)] right-[calc(16.67%+24px)] border-t-2 border-dashed border-purple-200/60"></div>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
            {steps.map((step) => (
              <div class="text-center relative">
                <div class="relative inline-flex items-center justify-center w-[68px] h-[68px] rounded-full bg-gradient-to-br from-purple-100 to-accent-pink/10 border-2 border-purple-200/50 mb-6">
                  <span class="text-xl font-bold bg-gradient-to-r from-purple-600 to-accent-pink bg-clip-text text-transparent">{step.num}</span>
                </div>
                <h3 class="text-lg font-semibold text-ink mb-2">{step.title}</h3>
                <p class="text-sm text-ink/50 leading-relaxed max-w-xs mx-auto">{step.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Features -->
      <section class="mb-24">
        <h2 class="text-2xl sm:text-3xl font-bold text-ink mb-4">Features</h2>
        <p class="text-ink/50 mb-12 max-w-2xl">Alles wat je nodig hebt, niets wat je niet nodig hebt.</p>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          {features.map((f) => (
            <div class="group relative bg-white rounded-2xl p-8 shadow-sm border border-purple-100/60 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 overflow-hidden">
              <!-- Top gradient border -->
              <div class={`absolute top-0 left-0 right-0 h-1 bg-gradient-to-r ${f.gradient}`}></div>
              <div class="mb-5 w-14 h-14 rounded-2xl bg-gradient-to-br from-purple-50 to-accent-pink/5 border border-purple-100/40 flex items-center justify-center" set:html={f.icon}></div>
              <h3 class="text-lg font-semibold text-ink mb-3">{f.title}</h3>
              <p class="text-sm text-ink/50 leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Oud vs Nieuw -->
      <section class="mb-24">
        <h2 class="text-2xl sm:text-3xl font-bold text-ink mb-4">Waarom EasyReimburse?</h2>
        <p class="text-ink/50 mb-12 max-w-2xl">Het verschil tussen de oude en de nieuwe manier van declareren.</p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <!-- Oud -->
          <div class="relative bg-red-50/50 rounded-2xl p-8 border border-red-200/40 overflow-hidden">
            <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-red-400 to-red-300"></div>
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-xl bg-red-100 flex items-center justify-center">
                <svg class="w-5 h-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-ink">De oude manier</h3>
            </div>
            <ul class="space-y-3">
              {oudVsNieuw.oud.map((item) => (
                <li class="flex items-start gap-3 text-sm text-ink/60">
                  <svg class="w-4 h-4 text-red-300 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <!-- Nieuw -->
          <div class="relative bg-green-50/50 rounded-2xl p-8 border border-green-200/40 overflow-hidden">
            <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-green-400 to-emerald-400"></div>
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-xl bg-green-100 flex items-center justify-center">
                <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-ink">Met EasyReimburse</h3>
            </div>
            <ul class="space-y-3">
              {oudVsNieuw.nieuw.map((item) => (
                <li class="flex items-start gap-3 text-sm text-ink/60">
                  <svg class="w-4 h-4 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <!-- Testimonial / trust -->
      <section class="mb-24">
        <div class="relative bg-white rounded-3xl p-10 sm:p-14 shadow-sm border border-purple-100/60 overflow-hidden">
          <div class="absolute top-0 left-0 w-1.5 h-full bg-gradient-to-b from-accent-pink to-purple-400 rounded-l-3xl"></div>
          <div class="pl-4 sm:pl-6">
            <svg class="w-10 h-10 text-purple-200 mb-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z" />
            </svg>
            <blockquote class="text-xl sm:text-2xl text-ink/70 leading-relaxed font-medium mb-6">
              "Ik bouwde EasyReimburse omdat ik zelf gek werd van het declaratieproces. Als het voor mij makkelijker moest, dan geldt dat voor duizenden andere bedrijven ook."
            </blockquote>
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-gradient-to-br from-purple-200 to-accent-pink/30 flex items-center justify-center">
                <span class="text-sm font-bold text-purple-600">MvZ</span>
              </div>
              <div>
                <p class="font-semibold text-ink text-sm">Micky van Zadelhoff</p>
                <p class="text-xs text-ink/40">Founder, EasyReimburse</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="mb-24">
        <div class="relative bg-gradient-to-br from-purple-600 to-purple-800 rounded-3xl p-10 sm:p-14 text-center overflow-hidden">
          <div class="absolute top-0 right-0 w-48 h-48 rounded-full bg-accent-pink/10 blur-2xl"></div>
          <div class="absolute bottom-0 left-0 w-32 h-32 rounded-full bg-white/5 blur-2xl"></div>
          <div class="relative">
            <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">Probeer EasyReimburse</h2>
            <p class="text-white/60 mb-8 max-w-lg mx-auto leading-relaxed">
              Benieuwd hoe het werkt? Bekijk de app en ontdek hoe simpel declareren kan zijn.
            </p>
            <a
              href="https://easyreimburse.ai"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 px-8 py-3 bg-white text-purple-700 font-semibold rounded-full hover:bg-purple-50 transition-colors shadow-lg"
            >
              Naar EasyReimburse
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
            </a>
            <p class="text-white/30 text-xs mt-4">easyreimburse.ai</p>
          </div>
        </div>
      </section>

    </div>
  </div>
</Layout>
