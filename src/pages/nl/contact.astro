---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
---

<Layout
  title="Contact — Micky van Zadelhoff"
  description="Neem contact op met Micky van Zadelhoff. Vragen over AI trainingen, samenwerkingen of gewoon een bakje koffie? Binnen 24 uur reactie."
  lang="nl"
>
  <PageHero
    title="Contact"
    subtitle="Heb je vragen over AI trainingen of kun je mijn hulp ergens bij gebruiken? Binnen 24 uur krijg je antwoord."
  />

  <div class="px-5 sm:px-8">
    <div class="max-w-5xl mx-auto">

      <div class="grid grid-cols-1 md:grid-cols-5 gap-12 md:gap-16 mb-20">

        <!-- Contact form -->
        <div class="md:col-span-3">
          <form class="space-y-6" action="#" method="POST">
            <div>
              <label for="name" class="block text-sm font-medium text-ink/50 mb-2">Naam</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full bg-white border border-purple-100/60 rounded-2xl px-4 py-3 text-ink placeholder:text-ink/20 focus:outline-none focus:border-purple-500/50 focus:ring-1 focus:ring-purple-500/50 transition-colors shadow-sm"
                placeholder="Je naam"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-ink/50 mb-2">E-mail</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full bg-white border border-purple-100/60 rounded-2xl px-4 py-3 text-ink placeholder:text-ink/20 focus:outline-none focus:border-purple-500/50 focus:ring-1 focus:ring-purple-500/50 transition-colors shadow-sm"
                placeholder="je@email.nl"
              />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-ink/50 mb-2">Bericht</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full bg-white border border-purple-100/60 rounded-2xl px-4 py-3 text-ink placeholder:text-ink/20 focus:outline-none focus:border-purple-500/50 focus:ring-1 focus:ring-purple-500/50 transition-colors resize-none shadow-sm"
                placeholder="Wat wil je weten of vragen?"
              ></textarea>
            </div>
            <button
              type="submit"
              class="px-8 py-3 bg-purple-600 text-white font-medium rounded-full hover:bg-purple-500 transition-colors"
            >
              Versturen
            </button>
          </form>
        </div>

        <!-- Contact details -->
        <div class="md:col-span-2">
          <div class="space-y-6">
            <div>
              <p class="text-xs uppercase tracking-[0.15em] text-ink/30 font-medium mb-2">E-mail</p>
              <a href="mailto:mick@demodernenomaden.nl" class="text-purple-600 hover:text-purple-600 transition-colors">
                mick@demodernenomaden.nl
              </a>
            </div>
            <div>
              <p class="text-xs uppercase tracking-[0.15em] text-ink/30 font-medium mb-2">WhatsApp</p>
              <a href="https://wa.me/31681081589" target="_blank" rel="noopener" class="text-purple-600 hover:text-purple-600 transition-colors">
                +31 6 81 08 15 89
              </a>
            </div>
            <div>
              <p class="text-xs uppercase tracking-[0.15em] text-ink/30 font-medium mb-2">KvK</p>
              <p class="text-ink/40 text-sm">62568299 (Rotterdam)</p>
            </div>
            <div>
              <p class="text-xs uppercase tracking-[0.15em] text-ink/30 font-medium mb-2">BTW</p>
              <p class="text-ink/40 text-sm">NL002317662B92</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
