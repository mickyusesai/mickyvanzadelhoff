---
import Layout from '../../../layouts/Layout.astro';
import PageHero from '../../../components/PageHero.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => {
  return data.lang === 'nl' && !data.draft;
});

const articles = allArticles.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Group by category
const categories = ['ondernemen', 'digitalenomaden', 'online-geld-verdienen', 'web3', 'tips', 'review'] as const;
const categoryLabels: Record<string, string> = {
  ondernemen: 'Ondernemen',
  digitalenomaden: 'Digitale Nomaden',
  'online-geld-verdienen': 'Online Geld Verdienen',
  web3: 'Web3 & Crypto',
  tips: 'Tips',
  review: 'Reviews',
};

const categoryEmojis: Record<string, string> = {
  ondernemen: '🚀',
  digitalenomaden: '🌍',
  'online-geld-verdienen': '💰',
  web3: '⛓️',
  tips: '💡',
  review: '⭐',
};

// Featured articles: 3 most recent
const featured = articles.slice(0, 3);
const remaining = articles.slice(3);
---

<Layout
  title="Blog — Micky van Zadelhoff"
  description="Artikelen over ondernemen, digital nomad leven, AI, online geld verdienen en meer. Door Micky van Zadelhoff."
  lang="nl"
>
  <PageHero
    title="Blog"
    subtitle="Artikelen over ondernemen, digital nomad leven, AI en meer."
    badge="176+ artikelen"
    gradient="purple"
  />

  <div class="px-5 sm:px-8">
    <div class="max-w-5xl mx-auto">

      <!-- Category filters -->
      <section class="mb-14">
        <div class="flex flex-wrap gap-3">
          <a
            href="/nl/blog/"
            class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold rounded-full bg-purple-600 text-white border-2 border-purple-600 shadow-md shadow-purple-500/15 transition-all duration-200"
          >
            <span class="text-base">📚</span>
            Alles
            <span class="text-xs opacity-70 ml-0.5 bg-white/20 px-2 py-0.5 rounded-full">{articles.length}</span>
          </a>
          {categories.map((cat) => {
            const count = articles.filter((a) => a.data.category === cat).length;
            return count > 0 ? (
              <a
                href={`/nl/blog/${cat}/`}
                class="group inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold rounded-full border-2 border-purple-100/60 text-ink/60 bg-white hover:bg-purple-600 hover:text-white hover:border-purple-600 hover:shadow-md hover:shadow-purple-500/15 transition-all duration-200 shadow-sm"
              >
                <span class="text-base">{categoryEmojis[cat]}</span>
                {categoryLabels[cat]}
                <span class="text-xs opacity-40 group-hover:opacity-70 ml-0.5 bg-purple-50 group-hover:bg-white/20 px-2 py-0.5 rounded-full transition-colors">{count}</span>
              </a>
            ) : null;
          })}
        </div>
      </section>

      <!-- Featured articles -->
      {featured.length > 0 && (
        <section class="mb-14">
          <h2 class="text-xl font-bold text-ink mb-8 flex items-center gap-3">
            <span class="w-10 h-1 bg-gradient-to-r from-purple-500 to-accent-pink rounded-full"></span>
            Uitgelicht
            <span class="w-10 h-1 bg-gradient-to-r from-accent-pink to-purple-300/30 rounded-full"></span>
          </h2>

          <!-- First featured: full width -->
          {featured[0] && (
            <a
              href={`/nl/blog/${featured[0].data.category}/${featured[0].id}/`}
              class="group block rounded-2xl overflow-hidden border border-purple-100/60 hover:border-purple-200 bg-white shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 mb-6"
            >
              <div class="grid grid-cols-1 md:grid-cols-2">
                <div class="aspect-video md:aspect-auto md:min-h-[300px] overflow-hidden bg-surface-200 relative">
                  {featured[0].data.featuredImage ? (
                    <img
                      src={featured[0].data.featuredImage}
                      alt={featured[0].data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                    />
                  ) : (
                    <div class="w-full h-full bg-gradient-to-br from-purple-200/50 via-accent-pink/25 to-accent-blue/15 relative">
                      <div class="absolute inset-0 flex items-center justify-center">
                        <span class="text-6xl opacity-20">{categoryEmojis[featured[0].data.category] || '📝'}</span>
                      </div>
                    </div>
                  )}
                  <div class="absolute top-4 left-4">
                    <span class="px-3 py-1 text-xs font-semibold bg-purple-600 text-white rounded-full shadow-lg">Nieuwste</span>
                  </div>
                </div>
                <div class="p-8 sm:p-10 flex flex-col justify-center">
                  <p class="text-xs text-ink/30 mb-3 flex items-center gap-2">
                    <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-purple-50/80 rounded-full text-purple-600/70 font-medium">
                      {categoryEmojis[featured[0].data.category]}
                      {categoryLabels[featured[0].data.category]}
                    </span>
                    <span class="text-ink/20">·</span>
                    {new Date(featured[0].data.date).toLocaleDateString('nl-NL', {
                      year: 'numeric', month: 'long', day: 'numeric',
                    })}
                  </p>
                  <h3 class="text-xl sm:text-2xl font-bold text-ink/80 group-hover:text-purple-600 transition-colors leading-snug mb-3">
                    {featured[0].data.title}
                  </h3>
                  {featured[0].data.description && (
                    <p class="text-sm text-ink/40 leading-relaxed line-clamp-3">{featured[0].data.description}</p>
                  )}
                  <span class="inline-flex items-center gap-1.5 text-sm text-purple-600 font-semibold mt-5 group-hover:gap-3 transition-all duration-300">
                    Lees meer
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
                  </span>
                </div>
              </div>
            </a>
          )}

          <!-- Next two featured: medium cards -->
          {featured.length > 1 && (
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              {featured.slice(1, 3).map((article) => (
                <a
                  href={`/nl/blog/${article.data.category}/${article.id}/`}
                  class="group block rounded-2xl overflow-hidden border border-purple-100/60 hover:border-purple-200 bg-white shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
                >
                  <div class="aspect-video overflow-hidden bg-surface-200 relative">
                    {article.data.featuredImage ? (
                      <img
                        src={article.data.featuredImage}
                        alt={article.data.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                        loading="lazy"
                      />
                    ) : (
                      <div class="w-full h-full bg-gradient-to-br from-purple-200/40 via-accent-pink/20 to-purple-100/30 relative">
                        <div class="absolute inset-0 flex items-center justify-center">
                          <span class="text-5xl opacity-15">{categoryEmojis[article.data.category] || '📝'}</span>
                        </div>
                      </div>
                    )}
                  </div>
                  <div class="p-6">
                    <p class="text-xs text-ink/30 mb-2 flex items-center gap-2">
                      <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-purple-50/60 rounded-full text-purple-600/60 font-medium text-[11px]">
                        {categoryEmojis[article.data.category]}
                        {categoryLabels[article.data.category]}
                      </span>
                      <span class="text-ink/15">·</span>
                      {new Date(article.data.date).toLocaleDateString('nl-NL', {
                        year: 'numeric', month: 'short', day: 'numeric',
                      })}
                    </p>
                    <h3 class="font-semibold text-ink/80 group-hover:text-purple-600 transition-colors line-clamp-2 text-base leading-snug mb-2">
                      {article.data.title}
                    </h3>
                    {article.data.description && (
                      <p class="text-xs text-ink/30 line-clamp-2">{article.data.description}</p>
                    )}
                  </div>
                </a>
              ))}
            </div>
          )}
        </section>
      )}

      <!-- Section divider -->
      <div class="flex items-center gap-4 mb-14">
        <div class="flex-1 h-px bg-gradient-to-r from-transparent via-purple-200/50 to-transparent"></div>
        <span class="text-xs uppercase tracking-widest text-ink/20 font-semibold px-4 py-1.5 bg-purple-50/50 rounded-full border border-purple-100/30">Alle artikelen</span>
        <div class="flex-1 h-px bg-gradient-to-r from-transparent via-purple-200/50 to-transparent"></div>
      </div>

      <!-- Articles grid -->
      <section class="mb-20">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {remaining.map((article) => (
            <a
              href={`/nl/blog/${article.data.category}/${article.id}/`}
              class="group block rounded-2xl overflow-hidden border border-purple-100/60 hover:border-purple-200 transition-all duration-300 bg-white shadow-sm hover:shadow-lg hover:-translate-y-1"
            >
              {article.data.featuredImage ? (
                <div class="aspect-video bg-surface-200 overflow-hidden">
                  <img
                    src={article.data.featuredImage}
                    alt={article.data.title}
                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 opacity-85 group-hover:opacity-100"
                    loading="lazy"
                  />
                </div>
              ) : (
                <div class="aspect-video bg-gradient-to-br from-purple-100/50 via-accent-pink/15 to-accent-blue/10 relative overflow-hidden">
                  <div class="absolute inset-0 flex items-center justify-center">
                    <span class="text-4xl opacity-20 group-hover:scale-110 transition-transform duration-500">{categoryEmojis[article.data.category] || '📝'}</span>
                  </div>
                  <div class="absolute bottom-0 left-0 right-0 h-1/3 bg-gradient-to-t from-white/20 to-transparent"></div>
                </div>
              )}
              <div class="p-5">
                <p class="text-xs text-ink/30 mb-2 flex items-center gap-1.5">
                  <span class="text-purple-600/50 font-medium">{categoryLabels[article.data.category]}</span>
                  <span class="text-ink/10">·</span>
                  {new Date(article.data.date).toLocaleDateString('nl-NL', {
                    year: 'numeric', month: 'short', day: 'numeric',
                  })}
                </p>
                <h3 class="font-semibold text-ink/80 group-hover:text-purple-600 transition-colors line-clamp-2 text-sm leading-snug">
                  {article.data.title}
                </h3>
                {article.data.description && (
                  <p class="text-xs text-ink/30 mt-2 line-clamp-2">{article.data.description}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    </div>
  </div>
</Layout>
