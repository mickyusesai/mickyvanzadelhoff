---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="pt-28 sm:pt-36 pb-12 sm:pb-16 px-5 sm:px-8">
  <div class="max-w-5xl mx-auto">
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-ink leading-tight mb-3">
      {title}
    </h1>
    {subtitle && (
      <p class="text-lg sm:text-xl text-ink/50 leading-relaxed max-w-2xl">
        {subtitle}
      </p>
    )}
  </div>
</section>
