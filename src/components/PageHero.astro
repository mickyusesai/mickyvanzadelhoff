---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="pt-32 sm:pt-40 pb-16 sm:pb-20 px-6 sm:px-10">
  <div class="max-w-4xl mx-auto">
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-4 leading-tight">
      {title}
    </h1>
    {subtitle && (
      <p class="text-lg sm:text-xl text-white/50 leading-relaxed max-w-2xl">
        {subtitle}
      </p>
    )}
  </div>
</section>
