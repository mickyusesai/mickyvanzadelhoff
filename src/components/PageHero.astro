---
interface Props {
  title: string;
  subtitle?: string;
  badge?: string;
  gradient?: 'purple' | 'pink' | 'blue' | 'warm';
  align?: 'left' | 'center';
}

const { title, subtitle, badge, gradient = 'purple', align = 'left' } = Astro.props;

const gradientMap = {
  purple: 'from-purple-100/80 via-surface to-surface',
  pink: 'from-accent-pink/15 via-purple-50/40 to-surface',
  blue: 'from-accent-blue/10 via-purple-50/30 to-surface',
  warm: 'from-accent-orange/10 via-accent-pink/10 to-surface',
};
---

<section class={`relative pt-28 sm:pt-36 pb-16 sm:pb-24 px-5 sm:px-8 overflow-hidden bg-gradient-to-br ${gradientMap[gradient]}`}>
  <!-- Decorative shapes -->
  <div class="absolute top-10 right-10 w-64 h-64 rounded-full bg-purple-200/20 blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-48 h-48 rounded-full bg-accent-pink/10 blur-3xl pointer-events-none"></div>
  <div class="absolute top-1/2 right-1/4 w-3 h-3 rounded-full bg-purple-400/30"></div>
  <div class="absolute top-1/3 left-1/3 w-2 h-2 rounded-full bg-accent-pink/40"></div>

  <div class={`relative max-w-5xl mx-auto ${align === 'center' ? 'text-center' : ''}`}>
    {badge && (
      <span class="inline-block px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-purple-700 bg-purple-100/80 rounded-full mb-6 border border-purple-200/50">
        {badge}
      </span>
    )}
    <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-ink leading-tight mb-4">
      {title}
    </h1>
    {subtitle && (
      <p class={`text-lg sm:text-xl text-ink/50 leading-relaxed ${align === 'center' ? 'max-w-2xl mx-auto' : 'max-w-2xl'}`}>
        {subtitle}
      </p>
    )}
  </div>

  <!-- Bottom fade line -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-purple-200/40 to-transparent"></div>
</section>
