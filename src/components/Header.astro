---
import { navigation, t, getAlternatePath } from '../lib/i18n';
import type { Locale } from '../lib/i18n';

interface Props {
  lang: Locale;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const navItems = navigation[lang];
const alternateLang: Locale = lang === 'nl' ? 'en' : 'nl';
const alternatePath = getAlternatePath(currentPath, lang);
const contactItem = navItems.find((item) => item.label === 'Contact');
const mainNavItems = navItems.filter((item) => item.label !== 'Contact');
---

<header class="sticky top-0 z-[60] bg-white/70 backdrop-blur-xl border-b border-purple-100/60">
  <div class="max-w-7xl mx-auto px-5 sm:px-8">
    <div class="flex items-center justify-between h-16 lg:h-[72px]">
      <!-- Wordmark -->
      <a href={`/${lang}/`} class="text-sm font-bold uppercase tracking-[0.15em] text-ink hover:text-purple-600 transition-colors shrink-0">
        Micky van Zadelhoff
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {mainNavItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'px-3.5 py-2 rounded-full text-[13px] font-medium transition-colors',
              currentPath === item.href || (item.href !== `/${lang}/` && currentPath.startsWith(item.href))
                ? 'text-purple-700 bg-purple-100/60'
                : 'text-ink/60 hover:text-ink hover:bg-surface-200/60',
            ]}
          >
            {item.label}
          </a>
        ))}
        <a
          href={alternatePath}
          class="px-3.5 py-2 rounded-full text-[13px] font-medium text-ink/40 hover:text-ink/70 transition-colors"
        >
          {t(lang, 'lang.switch')}
        </a>
        {contactItem && (
          <a
            href={contactItem.href}
            class="ml-2 px-5 py-2 rounded-full text-[13px] font-semibold bg-purple-600 text-white hover:bg-purple-700 transition-colors"
          >
            {contactItem.label}
          </a>
        )}
      </nav>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-lg text-ink/60 hover:text-ink hover:bg-surface-200/60 transition-colors"
        aria-label="Menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path id="menu-icon-open" stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          <path id="menu-icon-close" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" class="hidden" />
        </svg>
      </button>
    </div>

    <!-- Mobile nav -->
    <nav id="mobile-menu" class="lg:hidden hidden pb-6 pt-2">
      <div class="flex flex-col gap-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'px-4 py-3 rounded-xl text-sm font-medium transition-colors',
              currentPath === item.href || (item.href !== `/${lang}/` && currentPath.startsWith(item.href))
                ? 'text-purple-700 bg-purple-100/60'
                : 'text-ink/60 hover:text-ink hover:bg-surface-200/40',
            ]}
          >
            {item.label}
          </a>
        ))}
        <a
          href={alternatePath}
          class="px-4 py-3 rounded-xl text-sm font-medium text-ink/30 hover:text-ink/60 transition-colors"
        >
          {t(lang, 'lang.switch')}
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-icon-open');
  const closeIcon = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    if (expanded) {
      menu?.classList.add('hidden');
      openIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    } else {
      menu?.classList.remove('hidden');
      openIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
    }
  });
</script>
