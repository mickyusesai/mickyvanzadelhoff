---
import { navigation, t, getAlternatePath } from '../lib/i18n';
import type { Locale } from '../lib/i18n';

interface Props {
  lang: Locale;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const navItems = navigation[lang];
const alternateLang: Locale = lang === 'nl' ? 'en' : 'nl';
const alternatePath = getAlternatePath(currentPath, lang);
---

<header class="bg-white/80 backdrop-blur-sm border-b border-warm-200 sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16 sm:h-20">
      <!-- Logo / Name -->
      <a href={`/${lang}/`} class="text-lg sm:text-xl font-bold text-warm-900 hover:text-terra-600 transition-colors">
        Micky van Zadelhoff
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'px-3 py-2 rounded-lg text-sm font-medium transition-colors',
              currentPath === item.href || (item.href !== `/${lang}/` && currentPath.startsWith(item.href))
                ? 'bg-sand-100 text-terra-700'
                : 'text-warm-700 hover:text-terra-600 hover:bg-sand-50',
            ]}
          >
            {item.label}
          </a>
        ))}
        <a
          href={alternatePath}
          class="ml-2 px-3 py-1.5 text-sm font-medium text-terra-600 border border-terra-500 rounded-lg hover:bg-terra-500 hover:text-white transition-colors"
        >
          {t(lang, 'lang.switch')}
        </a>
      </nav>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-lg text-warm-700 hover:bg-sand-50 transition-colors"
        aria-label="Menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>

    <!-- Mobile nav -->
    <nav id="mobile-menu" class="lg:hidden hidden pb-4">
      <div class="flex flex-col gap-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'px-3 py-2.5 rounded-lg text-sm font-medium transition-colors',
              currentPath === item.href || (item.href !== `/${lang}/` && currentPath.startsWith(item.href))
                ? 'bg-sand-100 text-terra-700'
                : 'text-warm-700 hover:text-terra-600 hover:bg-sand-50',
            ]}
          >
            {item.label}
          </a>
        ))}
        <a
          href={alternatePath}
          class="mt-2 px-3 py-2.5 text-sm font-medium text-terra-600 border border-terra-500 rounded-lg hover:bg-terra-500 hover:text-white transition-colors text-center"
        >
          {t(lang, 'lang.switch')}
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });
</script>
