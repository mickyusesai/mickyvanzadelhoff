---
import { navigation, t } from '../lib/i18n';
import type { Locale } from '../lib/i18n';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const navItems = navigation[lang];
const year = new Date().getFullYear();
---

<footer class="bg-warm-900 text-warm-200 mt-auto">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 sm:gap-12">
      <!-- Brand -->
      <div>
        <p class="text-lg font-bold text-white mb-2">Micky van Zadelhoff</p>
        <p class="text-warm-400 text-sm leading-relaxed">
          {t(lang, 'footer.tagline')}
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <p class="text-sm font-semibold text-warm-300 uppercase tracking-wider mb-3">
          {lang === 'nl' ? 'Pagina\'s' : 'Pages'}
        </p>
        <nav class="flex flex-col gap-1.5">
          {navItems.slice(0, 5).map((item) => (
            <a href={item.href} class="text-sm text-warm-400 hover:text-white transition-colors">
              {item.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- More links -->
      <div>
        <p class="text-sm font-semibold text-warm-300 uppercase tracking-wider mb-3">
          {lang === 'nl' ? 'Meer' : 'More'}
        </p>
        <nav class="flex flex-col gap-1.5">
          {navItems.slice(5).map((item) => (
            <a href={item.href} class="text-sm text-warm-400 hover:text-white transition-colors">
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </div>

    <div class="border-t border-warm-800 mt-10 pt-6 text-center text-sm text-warm-500">
      &copy; {year} Micky van Zadelhoff
    </div>
  </div>
</footer>
